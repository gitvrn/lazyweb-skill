#!/usr/bin/env bash
# lazyweb-router — render + upsert + remove + status + refresh for the Lazyweb
# autorouter block (spec specs/autorouter.md). Bash entrypoint; node does all
# JSON/sha256/splice work (mirrors `setup`). No jq.
set -euo pipefail

# --- resolve repo ROOT, following a possible install symlink (~/.lazyweb/bin) ---
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$DIR/$SOURCE" ;; esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"

# shellcheck source=/dev/null
. "$SCRIPT_DIR/lazyweb-hosts.sh"

VERSION="$(cat "$ROOT/VERSION" 2>/dev/null || echo 0.0.0)"
TEMPLATE="$ROOT/router/ROUTER.template.md"
SKILLS_DIR="$ROOT/skills"
ROOT_SKILL="$ROOT/SKILL.md"
LW_HOME="${LAZYWEB_HOME:-$HOME/.lazyweb}"
MANIFEST="$LW_HOME/router.manifest.json"
CONFIG="$LW_HOME/config"
LOCK="$LW_HOME/router.manifest.lock"
BUDGET=1800

usage() {
  cat <<'USAGE'
Usage:
  lazyweb-router install [--host <h>|--all] [--yes]
  lazyweb-router remove  [--host <h>|--all]
  lazyweb-router status
  lazyweb-router render  --host <h>
  lazyweb-router refresh
  lazyweb-router decline
USAGE
}

# --- manifest lock (spec §10 M6): serialize manifest mutations -------------
acquire_lock() {
  mkdir -p "$LW_HOME"
  local i=0
  while ! mkdir "$LOCK" 2>/dev/null; do
    # stale-lock breaker: reclaim a lock older than 30s
    if [ -d "$LOCK" ]; then
      local age
      age="$(node -e 'try{const s=require("fs").statSync(process.argv[1]);process.stdout.write(String(Math.floor((Date.now()-s.mtimeMs)/1000)))}catch(e){process.stdout.write("999")}' "$LOCK" 2>/dev/null || echo 999)"
      [ "$age" -gt 30 ] && rmdir "$LOCK" 2>/dev/null || true
    fi
    i=$((i + 1))
    [ "$i" -gt 150 ] && { echo "lazyweb-router: could not acquire manifest lock" >&2; return 1; }
    sleep 0.2
  done
}
release_lock() { rmdir "$LOCK" 2>/dev/null || true; }

declined() { [ -f "$CONFIG" ] && grep -q '^router_declined=1' "$CONFIG" 2>/dev/null; }

# --- the node core: one target per call, dispatched by LW_ACTION -----------
# render  -> prints block to stdout
# install -> upserts block into LW_FILE, updates manifest, prints summary
# remove  -> strips block from LW_FILE, updates manifest
# status  -> prints "<host>: <state>"
run_node() {
  LW_ACTION="$1" LW_HOST="$2" LW_FILE="${3:-}" LW_PREAMBLE="${4:-}" \
  LW_VERSION="$VERSION" LW_TEMPLATE="$TEMPLATE" LW_SKILLS="$SKILLS_DIR" \
  LW_ROOTSKILL="$ROOT_SKILL" LW_HOME="$LW_HOME" LW_BUDGET="$BUDGET" \
  node <<'NODE'
'use strict';
const fs = require('fs');
const path = require('path');
const crypto = require('crypto');

const A = process.env.LW_ACTION;
const HOST = process.env.LW_HOST;
const FILE = process.env.LW_FILE || '';
const PRE = process.env.LW_PREAMBLE || '';
const VERSION = process.env.LW_VERSION || '0.0.0';
const TEMPLATE = process.env.LW_TEMPLATE;
const SKILLS = process.env.LW_SKILLS;
const ROOTSKILL = process.env.LW_ROOTSKILL;
const HOME = process.env.LW_HOME;
const BUDGET = parseInt(process.env.LW_BUDGET || '1800', 10);
const MANIFEST = path.join(HOME, 'router.manifest.json');
const BEGIN = '<!-- LAZYWEB:ROUTER:BEGIN';
const ENDM = '<!-- LAZYWEB:ROUTER:END -->';

function frontmatter(txt) {
  const m = txt.match(/^---\n([\s\S]*?)\n---/);
  return m ? m[1] : '';
}
function fmValue(fm, key) {
  const m = fm.match(new RegExp('^' + key + ':\\s*(.+)$', 'm'));
  if (!m) return '';
  return m[1].trim().replace(/^["']|["']$/g, '');
}
function firstSentence(fm) {
  // description may be a block scalar (`description: |`) — grab indented lines.
  const m = fm.match(/^description:\s*[|>]?\s*\n([\s\S]*?)(?=^\S|\Z)/m);
  let body = '';
  if (m) body = m[1];
  else {
    const inline = fm.match(/^description:\s*(.+)$/m);
    body = inline ? inline[1] : '';
  }
  body = body.replace(/\n\s*/g, ' ').trim();
  const dot = body.indexOf('.');
  return (dot >= 0 ? body.slice(0, dot) : body).trim();
}
function skillMeta(dir) {
  const f = path.join(SKILLS, dir, 'SKILL.md');
  if (!fs.existsSync(f)) return null;
  const fm = frontmatter(fs.readFileSync(f, 'utf8'));
  const name = fmValue(fm, 'name') || dir;
  const route = fmValue(fm, 'route') || firstSentence(fm) || name;
  return { dir, name, route };
}
function orderedSkills() {
  const dirs = fs.readdirSync(SKILLS, { withFileTypes: true })
    .filter((e) => e.isDirectory() && fs.existsSync(path.join(SKILLS, e.name, 'SKILL.md')))
    .map((e) => e.name);
  // Order by appearance in the root SKILL.md routing table (single source of
  // truth, spec §4.1); any skill not yet in that table is appended (alpha) so a
  // new mode is never stranded.
  const rootTxt = fs.readFileSync(ROOTSKILL, 'utf8');
  const tableOrder = [];
  for (const mm of rootTxt.matchAll(/skills\/([a-z0-9-]+)\/SKILL\.md/g)) {
    if (!tableOrder.includes(mm[1])) tableOrder.push(mm[1]);
  }
  const seen = new Set();
  const order = [];
  for (const d of tableOrder) if (dirs.includes(d) && !seen.has(d)) { order.push(d); seen.add(d); }
  for (const d of dirs.sort()) if (!seen.has(d)) { order.push(d); seen.add(d); }
  return order.map(skillMeta).filter(Boolean);
}
function renderRows() {
  const rows = orderedSkills().map((s) => `| ${s.route} | \`${s.name}\` |`);
  rows.push('| Anything UI-related that fits none of the above | `lazyweb` (the router skill picks the mode) |');
  return rows.join('\n');
}
function renderBlock() {
  let tpl = fs.readFileSync(TEMPLATE, 'utf8');
  tpl = tpl.replace(/\{\{VERSION\}\}/g, VERSION)
           .replace(/\{\{ACT_PREAMBLE\}\}/g, PRE)
           .replace(/\{\{ROWS\}\}/g, renderRows());
  if (tpl.includes('{{')) { console.error('lazyweb-router: unsubstituted placeholder in template'); process.exit(2); }
  return tpl.replace(/\s+$/, ''); // BEGIN..END, no trailing whitespace
}
function sha(s) { return crypto.createHash('sha256').update(s, 'utf8').digest('hex'); }
function readManifest() {
  try { const m = JSON.parse(fs.readFileSync(MANIFEST, 'utf8')); if (m && Array.isArray(m.targets)) return m; } catch (e) {}
  return { version: 1, targets: [] };
}
function writeManifest(m) {
  fs.mkdirSync(path.dirname(MANIFEST), { recursive: true });
  const tmp = MANIFEST + '.tmp';
  fs.writeFileSync(tmp, JSON.stringify(m, null, 2) + '\n');
  fs.renameSync(tmp, MANIFEST);
}
function atomicWrite(file, content, mode) {
  fs.mkdirSync(path.dirname(file), { recursive: true });
  const tmp = file + '.tmp';
  fs.writeFileSync(tmp, content);
  if (mode != null) { try { fs.chmodSync(tmp, mode); } catch (e) {} }
  fs.renameSync(tmp, file);
}
function liveBlock(text) {
  const bi = text.indexOf(BEGIN);
  if (bi < 0) return null;
  const ee = text.indexOf(ENDM, bi);
  if (ee < 0) return { corrupt: true };
  return { bi, after: ee + ENDM.length, str: text.slice(bi, ee + ENDM.length) };
}

if (A === 'render') { process.stdout.write(renderBlock() + '\n'); process.exit(0); }

if (A === 'status') {
  const m = readManifest();
  const entry = m.targets.find((t) => t.file === FILE);
  if (!entry) { console.log(`${HOST}: absent`); process.exit(0); }
  if (!fs.existsSync(FILE)) { console.log(`${HOST}: target missing (${FILE})`); process.exit(0); }
  const live = liveBlock(fs.readFileSync(FILE, 'utf8'));
  if (!live || live.corrupt) { console.log(`${HOST}: removed externally`); process.exit(0); }
  const state = sha(live.str) === entry.block_sha256 ? `installed v${entry.version}` : `modified (edited inside markers)`;
  console.log(`${HOST}: ${state} -> ${FILE}`);
  process.exit(0);
}

if (A === 'install') {
  const block = renderBlock();
  const bytes = Buffer.byteLength(block, 'utf8');
  if (bytes > BUDGET) console.error(`lazyweb-router: WARNING block is ${bytes}B (budget ${BUDGET}B) for ${HOST}`);
  let created = false, content, mode = null;
  if (!fs.existsSync(FILE)) {
    created = true; content = block + '\n';
  } else {
    try { mode = fs.statSync(FILE).mode; } catch (e) {}
    const cur = fs.readFileSync(FILE, 'utf8');
    const live = liveBlock(cur);
    if (live && live.corrupt) {
      console.error(`lazyweb-router: ${FILE} has a BEGIN marker without END — refusing to touch it. Fix it manually.`);
      process.exit(2);
    }
    if (live) {
      content = cur.slice(0, live.bi) + block + cur.slice(live.after); // replace in place
    } else {
      content = cur.replace(/\s+$/, '') + '\n\n' + block + '\n'; // append
    }
  }
  atomicWrite(FILE, content, mode);
  const m = readManifest();
  m.targets = m.targets.filter((t) => t.file !== FILE);
  m.targets.push({ host: HOST, file: FILE, version: VERSION, created_file: created, block_sha256: sha(block), updated_at: new Date().toISOString() });
  writeManifest(m);
  console.log(`${HOST}: installed v${VERSION} (${bytes}B, ${created ? 'created' : 'updated'}) -> ${FILE}`);
  process.exit(0);
}

if (A === 'remove') {
  const m = readManifest();
  const entry = m.targets.find((t) => t.file === FILE);
  if (fs.existsSync(FILE)) {
    const cur = fs.readFileSync(FILE, 'utf8');
    const live = liveBlock(cur);
    if (live && !live.corrupt) {
      let rest = cur.slice(0, live.bi).replace(/\n+$/, '\n') + cur.slice(live.after);
      rest = rest.replace(/\n{3,}/g, '\n\n');
      if (entry && entry.created_file && rest.trim() === '') {
        fs.unlinkSync(FILE);
        console.log(`${HOST}: removed block and deleted ${FILE} (was created by us)`);
      } else {
        atomicWrite(FILE, rest.replace(/\s+$/, '') + '\n');
        console.log(`${HOST}: removed block from ${FILE}`);
      }
    } else {
      console.log(`${HOST}: no block found in ${FILE}`);
    }
  } else {
    console.log(`${HOST}: target file already gone`);
  }
  m.targets = m.targets.filter((t) => t.file !== FILE);
  writeManifest(m);
  process.exit(0);
}

console.error('lazyweb-router: unknown node action ' + A);
process.exit(2);
NODE
}

# --- argument parsing ------------------------------------------------------
CMD="${1:-}"; shift || true
SEL_HOST=""; ALL=0; YES=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --host) SEL_HOST="${2:-}"; shift 2 ;;
    --host=*) SEL_HOST="${1#--host=}"; shift ;;
    --all) ALL=1; shift ;;
    --yes|-y) YES=1; shift ;;
    *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
done

selected_targets() {
  if [ -n "$SEL_HOST" ]; then printf '%s\n' "$SEL_HOST"; return; fi
  if [ "$ALL" -eq 1 ]; then host_all; return; fi
  host_all
}

case "$CMD" in
  render)
    [ -n "$SEL_HOST" ] || { echo "render needs --host <h>" >&2; exit 1; }
    run_node render "$SEL_HOST" "" "$(host_act_preamble "$SEL_HOST")"
    ;;

  install)
    if declined && [ "$YES" -ne 1 ]; then
      echo "lazyweb-router: routing previously declined (rm $CONFIG to re-enable, or pass --yes)" >&2
      exit 0
    fi
    # Consent gate: need --yes, or an interactive TTY confirmation.
    if [ "$YES" -ne 1 ]; then
      if [ -t 0 ]; then
        echo "Will add the Lazyweb routing block to:"
        for h in $(selected_targets); do
          host_routable "$h" || continue
          echo "  - $h: $(host_instruction_file "$h")"
        done
        printf 'Proceed? [y/N] '
        read -r ans || ans=""
        case "$ans" in y|Y|yes|Yes|YES) ;; *) echo "Aborted."; exit 0 ;; esac
      else
        echo "lazyweb-router: refusing to write without --yes (no TTY for confirmation)" >&2
        exit 3
      fi
    fi
    acquire_lock || exit 1
    trap release_lock EXIT
    rc=0; wrote=0
    for h in $(selected_targets); do
      if ! host_routable "$h"; then
        if [ -n "$SEL_HOST" ]; then
          echo "$h: not routable (no skills installed and/or capability flag off) — skipped" >&2
          rc=1
        fi
        continue
      fi
      run_node install "$h" "$(host_instruction_file "$h")" "$(host_act_preamble "$h")" || rc=1
      wrote=1
    done
    # Manual install clears a prior decline on success.
    if [ "$wrote" -eq 1 ] && declined; then
      grep -v '^router_declined=1' "$CONFIG" > "$CONFIG.tmp" 2>/dev/null || true
      mv "$CONFIG.tmp" "$CONFIG" 2>/dev/null || true
    fi
    exit "$rc"
    ;;

  remove)
    acquire_lock || exit 1
    trap release_lock EXIT
    for h in $(selected_targets); do
      f="$(host_instruction_file "$h")"
      [ -n "$f" ] || continue
      run_node remove "$h" "$f" || true
    done
    ;;

  status)
    for h in $(host_all); do
      f="$(host_instruction_file "$h")"
      [ -n "$f" ] || { echo "$h: no user-level target (project-fallback host)"; continue; }
      run_node status "$h" "$f" || true
    done
    ;;

  refresh)
    [ -f "$MANIFEST" ] || { echo "no manifest; nothing to refresh"; exit 0; }
    acquire_lock || exit 1
    trap release_lock EXIT
    for h in $(host_all); do
      f="$(host_instruction_file "$h")"
      [ -n "$f" ] || continue
      if grep -q "\"file\": \"$f\"" "$MANIFEST" 2>/dev/null; then
        host_routable "$h" || continue
        run_node install "$h" "$f" "$(host_act_preamble "$h")" || true
      fi
    done
    ;;

  decline)
    mkdir -p "$LW_HOME"
    grep -q '^router_declined=1' "$CONFIG" 2>/dev/null || echo 'router_declined=1' >> "$CONFIG"
    echo "Recorded decline (router_declined=1 in $CONFIG)."
    ;;

  ''|-h|--help|help) usage ;;
  *) echo "Unknown command: $CMD" >&2; usage >&2; exit 1 ;;
esac
