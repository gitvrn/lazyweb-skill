{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/lazyweb-log query" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__.*lazyweb__.*",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/lazyweb-log tool" }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "mcp__.*lazyweb__.*",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/lazyweb-log tool-failure" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/lazyweb-log stop" }
        ]
      }
    ]
  }
}
