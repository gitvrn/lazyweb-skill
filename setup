#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
MCP_URL="${LAZYWEB_MCP_URL:-https://www.lazyweb.com/mcp}"
INSTALL_TOKEN_URL="${LAZYWEB_INSTALL_TOKEN_URL:-https://www.lazyweb.com/api/mcp/install-token}"
TOKEN_FILE="${LAZYWEB_TOKEN_FILE:-$HOME/.lazyweb/lazyweb_mcp_token}"
AUTO_UPDATE_MARKER="${LAZYWEB_AUTO_UPDATE_MARKER:-$HOME/.lazyweb/auto_update}"
HOST="auto"
QUIET=0
AUTO_UPDATE_CHOICE=""
ROUTER_CHOICE=""

usage() {
  cat <<'USAGE'
Usage: ./setup [--host auto|all|codex|claude|cursor|opencode|kiro|factory|slate|hermes|antigravity] [--quiet] [--auto-update|--no-auto-update] [--router|--no-router]

Installs the standalone Lazyweb skill pack and configures direct Lazyweb MCP
access for supported local coding clients.

Flags:
  --auto-update     Opt in to silent automatic updates (creates
                    ~/.lazyweb/auto_update). Skips the interactive prompt.
  --no-auto-update  Opt out and skip the prompt; updates remain advisory.
  --router          Install the Lazyweb autorouter (a marked routing block in
                    each agent's global instruction file) without the prompt.
  --no-router       Skip the autorouter and persist the decline.
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --host)
      [ "${2:-}" ] || { echo "Missing value for --host" >&2; exit 1; }
      HOST="$2"
      shift 2
      ;;
    --host=*)
      HOST="${1#--host=}"
      shift
      ;;
    -q|--quiet)
      QUIET=1
      shift
      ;;
    --auto-update)
      AUTO_UPDATE_CHOICE="on"
      shift
      ;;
    --no-auto-update)
      AUTO_UPDATE_CHOICE="off"
      shift
      ;;
    --router)
      ROUTER_CHOICE="on"
      shift
      ;;
    --no-router)
      ROUTER_CHOICE="off"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

log() {
  [ "$QUIET" -eq 1 ] || printf '%s\n' "$*"
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

json_escape() {
  node -e 'process.stdout.write(JSON.stringify(process.argv[1]))' "$1"
}

link_or_copy() {
  local src="$1"
  local dst="$2"
  rm -rf "$dst"
  if ln -s "$src" "$dst" 2>/dev/null; then
    return 0
  fi
  if [ -d "$src" ]; then
    cp -R "$src" "$dst"
  else
    cp "$src" "$dst"
  fi
}

ensure_token() {
  mkdir -p "$(dirname "$TOKEN_FILE")"

  if [ -n "${LAZYWEB_MCP_TOKEN:-}" ]; then
    printf '%s\n' "$LAZYWEB_MCP_TOKEN" > "$TOKEN_FILE"
    chmod 600 "$TOKEN_FILE" 2>/dev/null || true
    printf '%s' "$LAZYWEB_MCP_TOKEN"
    return 0
  fi

  if [ -s "$TOKEN_FILE" ]; then
    tr -d '[:space:]' < "$TOKEN_FILE"
    return 0
  fi

  [ "$QUIET" -eq 1 ] || printf '%s\n' "Creating a free Lazyweb MCP token..." >&2
  local token
  token="$(curl -fsS -X POST "$INSTALL_TOKEN_URL" -H "content-type: application/json" -d '{}' \
    | node -e "let s='';process.stdin.on('data',d=>s+=d);process.stdin.on('end',()=>{const j=JSON.parse(s); process.stdout.write(j.token || j.userId || '');})")"
  if [ -z "$token" ]; then
    echo "Failed to create Lazyweb MCP token from $INSTALL_TOKEN_URL" >&2
    exit 1
  fi
  printf '%s\n' "$token" > "$TOKEN_FILE"
  chmod 600 "$TOKEN_FILE" 2>/dev/null || true
  printf '%s' "$token"
}

install_skills_to_root() {
  local skills_root="$1"
  mkdir -p "$skills_root"
  rm -rf "$skills_root/lazyweb"
  mkdir -p "$skills_root/lazyweb"
  link_or_copy "$ROOT/SKILL.md" "$skills_root/lazyweb/SKILL.md"
  # Iterate every skill directory under $ROOT/skills. Avoids the
  # hardcoded-list trap that left lazyweb-paywall-cta and
  # lazyweb-signup-optimization stranded on disk after 0.4.0.
  local skill_dir_path skill_dir
  for skill_dir_path in "$ROOT/skills"/*/; do
    [ -d "$skill_dir_path" ] || continue
    skill_dir="$(basename "$skill_dir_path")"
    link_or_copy "$ROOT/skills/$skill_dir" "$skills_root/$skill_dir"
  done
}

# Propagate the published pack version to a known location so the
# server-side instructions string's `cat $HOME/.lazyweb/VERSION` reads
# a real value instead of falling back to 0.0.0 (which would falsely
# look stale forever).
install_version_marker() {
  mkdir -p "$HOME/.lazyweb"
  if [ -f "$ROOT/VERSION" ]; then
    cp "$ROOT/VERSION" "$HOME/.lazyweb/VERSION"
  fi
}

install_lazyweb_bins() {
  mkdir -p "$HOME/.lazyweb/bin"
  # lazyweb-hosts.sh is sourced by lazyweb-router and must sit beside it.
  for bin_name in lazyweb-context-detect lazyweb-hosts.sh lazyweb-log lazyweb-router lazyweb-telemetry-flush lazyweb-update lazyweb-update-check; do
    [ -f "$ROOT/bin/$bin_name" ] || continue
    link_or_copy "$ROOT/bin/$bin_name" "$HOME/.lazyweb/bin/$bin_name"
    chmod +x "$HOME/.lazyweb/bin/$bin_name" 2>/dev/null || true
  done
}

write_codex_mcp_config() {
  local config_path="${CODEX_HOME:-$HOME/.codex}/config.toml"
  mkdir -p "$(dirname "$config_path")"
  CONFIG_PATH="$config_path" MCP_URL="$MCP_URL" node <<'NODE'
const fs = require("fs");
const path = require("path");

const configPath = process.env.CONFIG_PATH;
const mcpUrl = process.env.MCP_URL;
const command = `TOKEN="\${LAZYWEB_MCP_TOKEN:-}"; if [ -z "$TOKEN" ] && [ -f "$HOME/.lazyweb/lazyweb_mcp_token" ]; then TOKEN="$(cat "$HOME/.lazyweb/lazyweb_mcp_token")"; fi; exec npx -y mcp-remote ${mcpUrl} --header "Authorization: Bearer $TOKEN" --transport http-first`;
const block = [
  "[mcp_servers.lazyweb]",
  'command = "sh"',
  `args = ["-lc", ${JSON.stringify(command)}]`,
  ""
].join("\n");

let text = "";
try {
  text = fs.readFileSync(configPath, "utf8");
} catch (err) {
  if (err.code !== "ENOENT") throw err;
}

const lines = text.split(/\n/);
const out = [];
let skipping = false;
for (const line of lines) {
  if (/^\s*\[mcp_servers\.lazyweb\]\s*$/.test(line)) {
    skipping = true;
    continue;
  }
  if (skipping && /^\s*\[[^\]]+\]\s*$/.test(line)) {
    skipping = false;
  }
  if (!skipping) out.push(line);
}

const next = out.join("\n").trimEnd();
fs.mkdirSync(path.dirname(configPath), { recursive: true });
fs.writeFileSync(configPath, `${next}${next ? "\n\n" : ""}${block}`);
NODE
}

write_json_mcp_config() {
  local config_path="$1"
  local url_key="$2"
  local token="$3"
  mkdir -p "$(dirname "$config_path")"
  CONFIG_PATH="$config_path" MCP_URL="$MCP_URL" URL_KEY="$url_key" TOKEN="$token" node <<'NODE'
const fs = require("fs");
const path = require("path");

const configPath = process.env.CONFIG_PATH;
const urlKey = process.env.URL_KEY;
const mcpUrl = process.env.MCP_URL;
const token = process.env.TOKEN;
let data = {};
try {
  data = JSON.parse(fs.readFileSync(configPath, "utf8"));
} catch (err) {
  if (err.code !== "ENOENT") data = {};
}

if (!data || typeof data !== "object" || Array.isArray(data)) data = {};
if (!data.mcpServers || typeof data.mcpServers !== "object" || Array.isArray(data.mcpServers)) {
  data.mcpServers = {};
}
data.mcpServers.lazyweb = {
  [urlKey]: mcpUrl,
  headers: {
    Authorization: `Bearer ${token}`,
    Accept: "application/json, text/event-stream"
  },
  disabled: false
};
fs.mkdirSync(path.dirname(configPath), { recursive: true });
fs.writeFileSync(configPath, `${JSON.stringify(data, null, 2)}\n`);
NODE
}

configure_claude_mcp() {
  local token="$1"
  if ! has_cmd claude; then
    log "Claude Code CLI not found; skipping Claude MCP auto-config."
    return 0
  fi
  claude mcp remove -s user lazyweb >/dev/null 2>&1 || true
  claude mcp add --transport http --scope user lazyweb "$MCP_URL" --header "Authorization: Bearer $token" >/dev/null
}

selected_hosts() {
  case "$HOST" in
    all)
      printf '%s\n' codex claude cursor opencode kiro factory slate hermes antigravity
      ;;
    codex|claude|cursor|opencode|kiro|factory|slate|hermes|antigravity)
      printf '%s\n' "$HOST"
      ;;
    auto)
      { has_cmd codex || [ -d "$HOME/.codex" ]; } && printf '%s\n' codex
      { has_cmd claude || [ -d "$HOME/.claude" ]; } && printf '%s\n' claude
      { has_cmd cursor || [ -d "$HOME/.cursor" ]; } && printf '%s\n' cursor
      { has_cmd opencode || [ -d "$HOME/.config/opencode" ]; } && printf '%s\n' opencode
      { has_cmd kiro || [ -d "$HOME/.kiro" ]; } && printf '%s\n' kiro
      { has_cmd droid || [ -d "$HOME/.factory" ]; } && printf '%s\n' factory
      [ -d "$HOME/.slate" ] && printf '%s\n' slate
      [ -d "$HOME/.hermes" ] && printf '%s\n' hermes
      { has_cmd antigravity || has_cmd antigravity-cli || [ -d "$HOME/.gemini/antigravity" ] || [ -d "$HOME/.gemini/antigravity-cli" ] || [ -d "$HOME/.gemini/antigravity-ide" ]; } && printf '%s\n' antigravity
      ;;
    *)
      echo "Unknown --host value: $HOST" >&2
      exit 1
      ;;
  esac
}

TOKEN="$(ensure_token)"
install_lazyweb_bins
install_version_marker

HOSTS="$(selected_hosts | awk '!seen[$0]++' || true)"
if [ -z "$HOSTS" ]; then
  printf '%s\n' "No supported local coding clients were detected."
else
  for host in $HOSTS; do
    case "$host" in
      codex)
        install_skills_to_root "${CODEX_HOME:-$HOME/.codex}/skills"
        write_codex_mcp_config
        log "Installed Lazyweb skills and MCP config for Codex."
        ;;
      claude)
        install_skills_to_root "$HOME/.claude/skills"
        configure_claude_mcp "$TOKEN"
        log "Installed Lazyweb skills and MCP config for Claude Code."
        ;;
      cursor)
        install_skills_to_root "$HOME/.cursor/skills"
        write_json_mcp_config "$HOME/.cursor/mcp.json" "url" "$TOKEN"
        log "Installed Lazyweb skills and MCP config for Cursor."
        ;;
      opencode)
        install_skills_to_root "$HOME/.config/opencode/skills"
        log "Installed Lazyweb skills for OpenCode. Add the manual MCP config below if OpenCode does not already share an MCP config."
        ;;
      kiro)
        install_skills_to_root "$HOME/.kiro/skills"
        log "Installed Lazyweb skills for Kiro. Add the manual MCP config below if Kiro does not already share an MCP config."
        ;;
      factory)
        install_skills_to_root "$HOME/.factory/skills"
        log "Installed Lazyweb skills for Factory Droid. Add the manual MCP config below if Factory does not already share an MCP config."
        ;;
      slate)
        install_skills_to_root "$HOME/.slate/skills"
        log "Installed Lazyweb skills for Slate. Add the manual MCP config below if Slate does not already share an MCP config."
        ;;
      hermes)
        install_skills_to_root "$HOME/.hermes/skills"
        log "Installed Lazyweb skills for Hermes. Add the manual MCP config below if Hermes does not already share an MCP config."
        ;;
      antigravity)
        write_json_mcp_config "$HOME/.gemini/antigravity/mcp_config.json" "serverUrl" "$TOKEN"
        write_json_mcp_config "$HOME/.gemini/antigravity-cli/mcp_config.json" "serverUrl" "$TOKEN"
        write_json_mcp_config "$HOME/.gemini/antigravity-ide/mcp_config.json" "serverUrl" "$TOKEN"
        log "Installed Lazyweb MCP config for Antigravity."
        ;;
    esac
  done
fi

# Autorouter refresh (specs/autorouter.md §7.4): every consented routing block
# is silently re-rendered so the injected table stays in lockstep with the
# skill list. No manifest -> no-op. Never blocks setup.
if [ -s "$HOME/.lazyweb/router.manifest.json" ]; then
  "$ROOT/bin/lazyweb-router" refresh >/dev/null 2>&1 || true
fi

cat <<EOF

Lazyweb setup complete.

Welcome to Lazyweb.
Hey, Ali here through your agent. I am the founder of Lazyweb. Thanks for installing our MCP.
Lazyweb gives your agent real product screenshots, product flows, and UI patterns before it designs.

Try these first:
  1. Ask what the main Lazyweb usage modes are.
  2. Ask for quick references for a specific screen, like onboarding welcome screens, pricing pages, paywalls, dashboards, checkout, or settings.
  3. Ask for deeper design research before changing a landing page, app flow, onboarding, paywall, checkout, dashboard, or settings screen.
  4. Ask Lazyweb to compare your current UI against strong product examples and turn the patterns into concrete changes.

Token file:
  $TOKEN_FILE

Manual MCP config for any unsupported local client:
  URL: $MCP_URL
  Transport: Streamable HTTP
  Header: Authorization: Bearer $TOKEN

First checks:
  1. Reload/restart the client.
  2. Show the Welcome to Lazyweb message above to the user.
  3. List MCP tools and confirm lazyweb_get_workflows is present.
  4. Call lazyweb_get_workflows with operation=list and task_context="first run Lazyweb capabilities"; summarize the returned workflows as Lazyweb's super powers.
  5. Do not call lazyweb_get_flows for the first-run capability guide. That is a separate tool for ordered product journeys.
EOF

# Auto-update opt-in. Resolved explicitly via --auto-update / --no-auto-update,
# otherwise prompted once interactively. Quiet, non-interactive, and previously
# answered installs leave the existing marker alone.
case "$AUTO_UPDATE_CHOICE" in
  on)
    mkdir -p "$(dirname "$AUTO_UPDATE_MARKER")"
    touch "$AUTO_UPDATE_MARKER"
    log "Auto-updates enabled. Disable later: rm $AUTO_UPDATE_MARKER"
    ;;
  off)
    log "Auto-updates left off. Enable later: touch $AUTO_UPDATE_MARKER"
    ;;
  *)
    if [ "$QUIET" -eq 0 ] && [ -t 0 ] && [ ! -f "$AUTO_UPDATE_MARKER" ]; then
      printf '\nEnable auto-updates so future Lazyweb skill changes apply silently? [Y/n] '
      if read -r LAZYWEB_AUTO_ANSWER; then
        case "$LAZYWEB_AUTO_ANSWER" in
          n|N|no|No|NO)
            log "Auto-updates left off. Enable later: touch $AUTO_UPDATE_MARKER"
            ;;
          *)
            mkdir -p "$(dirname "$AUTO_UPDATE_MARKER")"
            touch "$AUTO_UPDATE_MARKER"
            log "Auto-updates enabled. Disable later: rm $AUTO_UPDATE_MARKER"
            ;;
        esac
      fi
    fi
    ;;
esac

# Autorouter opt-in (specs/autorouter.md §7.1). Resolved explicitly via
# --router / --no-router, otherwise offered once interactively with a preview.
# Quiet/piped installs NEVER inject: MCP configs are tooling, but instruction
# files are user-authored prose — explicit consent only; they get a tip line.
ROUTER_BIN="$ROOT/bin/lazyweb-router"
ROUTER_MANIFEST="$HOME/.lazyweb/router.manifest.json"
router_declined_flag() {
  grep -q '^router_declined=1' "$HOME/.lazyweb/config" 2>/dev/null
}
case "$ROUTER_CHOICE" in
  on)
    "$ROUTER_BIN" install --all --yes || true
    log "Autorouter installed. Remove later: ~/.lazyweb/bin/lazyweb-router remove --all"
    ;;
  off)
    "$ROUTER_BIN" decline >/dev/null 2>&1 || true
    log "Autorouter left off. Enable later: ~/.lazyweb/bin/lazyweb-router install"
    ;;
  *)
    if [ -s "$ROUTER_MANIFEST" ] || router_declined_flag; then
      : # already resolved (installed earlier, or declined) — never re-ask
    elif [ "$QUIET" -eq 0 ] && [ -t 0 ]; then
      # Preview with the first routable host so the user sees the exact block.
      # shellcheck source=/dev/null
      . "$ROOT/bin/lazyweb-hosts.sh"
      ROUTER_PREVIEW_HOST=""
      for _rh in $(host_all); do
        if host_routable "$_rh"; then ROUTER_PREVIEW_HOST="$_rh"; break; fi
      done
      if [ -n "$ROUTER_PREVIEW_HOST" ]; then
        printf '\nLazyweb can add this routing section to your agents'\'' global instruction\nfiles so design questions auto-route to the right Lazyweb mode:\n\n'
        "$ROUTER_BIN" render --host "$ROUTER_PREVIEW_HOST" 2>/dev/null || true
        printf '\nAdd Lazyweb routing to your agents'\'' global instructions? [y/N] '
        if read -r LAZYWEB_ROUTER_ANSWER; then
          case "$LAZYWEB_ROUTER_ANSWER" in
            y|Y|yes|Yes|YES)
              "$ROUTER_BIN" install --all --yes || true
              ;;
            n|N|no|No|NO)
              "$ROUTER_BIN" decline || true
              ;;
            *)
              # No answer (M7): skip WITHOUT persisting a decline, so the
              # once-per-session MCP offer remains the single follow-up.
              log "Skipped for now. Add later: ~/.lazyweb/bin/lazyweb-router install"
              ;;
          esac
        fi
      fi
    elif [ "$QUIET" -eq 0 ]; then
      printf '\nTip: run ~/.lazyweb/bin/lazyweb-router install to auto-route design questions\nto the right Lazyweb mode (adds a marked block to your agents'\'' instructions).\n'
    fi
    ;;
esac
